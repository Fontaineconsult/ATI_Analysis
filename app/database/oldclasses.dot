    // Indicators subgraph
    subgraph cluster_Indicators {
    label = "Indicators";
    style = filled;
    color = yellow;

    "SuccessIndicator" [color="black", fontcolor="black", label=<{SuccessIndicator|composite_key : StringProperty<br ALIGN="LEFT"/>date_added : DateProperty<br ALIGN="LEFT"/>directed_plans : RelationshipTo<br ALIGN="LEFT"/>directed_procedures : RelationshipTo<br ALIGN="LEFT"/>directed_processes : RelationshipTo<br ALIGN="LEFT"/>directed_projects : RelationshipTo<br ALIGN="LEFT"/>directed_services : RelationshipTo<br ALIGN="LEFT"/>notes : RelationshipTo<br ALIGN="LEFT"/>number : IntegerProperty<br ALIGN="LEFT"/>removed : BooleanProperty<br ALIGN="LEFT"/>success_indicator : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "Goal" [color="black", fontcolor="black", label=<{Goal|date_added : DateProperty<br ALIGN="LEFT"/>description : StringProperty<br ALIGN="LEFT"/>goal : StringProperty<br ALIGN="LEFT"/>goal_number : IntegerProperty<br ALIGN="LEFT"/>removed : BooleanProperty<br ALIGN="LEFT"/>supporting_success_indicators : RelationshipTo<br ALIGN="LEFT"/>title : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
