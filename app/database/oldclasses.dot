    "College" -> "Project" [label="implements"];
    "College" -> "Procedure" [label="implements"];
    "College" -> "Service" [label="implements"];
    }
    // Documentation subgraph
    subgraph cluster_Documentation {
    label = "Documentation";
    style = filled;
    color = purple;

    "Document" [color="black", fontcolor="black", label=<{Document|file_path : StringProperty<br ALIGN="LEFT"/>hash : StringProperty<br ALIGN="LEFT"/>is_administrative_review_documentation : StringProperty<br ALIGN="LEFT"/>is_milestone_and_measures_documentation : StringProperty<br ALIGN="LEFT"/>name : StringProperty<br ALIGN="LEFT"/>notes : RelationshipTo<br ALIGN="LEFT"/>uri_path : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "Webpage" [color="black", fontcolor="black", label=<{Webpage|description : StringProperty<br ALIGN="LEFT"/>notes : RelationshipTo<br ALIGN="LEFT"/>title : StringProperty<br ALIGN="LEFT"/>url : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "Note" [color="black", fontcolor="black", label=<{Note|content : StringProperty<br ALIGN="LEFT"/>date_created : DateProperty<br ALIGN="LEFT"/>uuid : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "Message" [color="black", fontcolor="black", label=<{Message|content : StringProperty<br ALIGN="LEFT"/>date_created : StringProperty<br ALIGN="LEFT"/>type : StringProperty<br ALIGN="LEFT"/>uuid : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
