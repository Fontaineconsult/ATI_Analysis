    // Organizational Units subgraph
    subgraph cluster_OrganizationalUnits {
    label = "Organizational Units";
    style = filled;
    color = red;

    "Vendor" [color="black", fontcolor="black", label=<{Vendor|employs : RelationshipTo<br ALIGN="LEFT"/>implements_procedure : RelationshipTo<br ALIGN="LEFT"/>implements_process : RelationshipTo<br ALIGN="LEFT"/>implements_project : RelationshipTo<br ALIGN="LEFT"/>implements_service : RelationshipTo<br ALIGN="LEFT"/>location : StringProperty<br ALIGN="LEFT"/>name : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "Department" [color="black", fontcolor="black", label=<{Department|employs : RelationshipTo<br ALIGN="LEFT"/>implements_procedure : RelationshipTo<br ALIGN="LEFT"/>implements_process : RelationshipTo<br ALIGN="LEFT"/>implements_project : RelationshipTo<br ALIGN="LEFT"/>implements_service : RelationshipTo<br ALIGN="LEFT"/>location : StringProperty<br ALIGN="LEFT"/>name : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "College" [color="black", fontcolor="black", label=<{College|employs : RelationshipTo<br ALIGN="LEFT"/>implements_procedure : RelationshipTo<br ALIGN="LEFT"/>implements_process : RelationshipTo<br ALIGN="LEFT"/>implements_project : RelationshipTo<br ALIGN="LEFT"/>implements_service : RelationshipTo<br ALIGN="LEFT"/>location : StringProperty<br ALIGN="LEFT"/>name : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "Vendor" -> "Person" [label="employs"];
    "Vendor" -> "Process" [label="implements"];
    "Vendor" -> "Project" [label="implements"];
    "Vendor" -> "Procedure" [label="implements"];
    "Vendor" -> "Service" [label="implements"];
    "Department" -> "Person" [label="employs"];
    "Department" -> "Process" [label="implements"];
    "Department" -> "Project" [label="implements"];
    "Department" -> "Procedure" [label="implements"];
    "Department" -> "Service" [label="implements"];
    "College" -> "Person" [label="employs"];
