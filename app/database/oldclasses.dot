digraph "classes_ati-ont" {
    rankdir=RL;
    charset="utf-8";




    // Governance subgraph
    subgraph cluster_Governance {
    label = "Governance";
    style = filled;
    color = lightgrey;

    "Policy" [color="black", fontcolor="black", label=<{Policy|description : StringProperty<br ALIGN="LEFT"/>effective_date : DateProperty<br ALIGN="LEFT"/>informed_indicators : RelationshipTo<br ALIGN="LEFT"/>last_updated : DateProperty<br ALIGN="LEFT"/>supporting_documents : RelationshipTo<br ALIGN="LEFT"/>supporting_messages : RelationshipTo<br ALIGN="LEFT"/>supporting_notes : RelationshipTo<br ALIGN="LEFT"/>supporting_websites : RelationshipTo<br ALIGN="LEFT"/>title : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "Memo" [color="black", fontcolor="black", label=<{Memo|authored_date : DateProperty<br ALIGN="LEFT"/>description : StringProperty<br ALIGN="LEFT"/>informed_indicators : RelationshipTo<br ALIGN="LEFT"/>supporting_documents : RelationshipTo<br ALIGN="LEFT"/>supporting_messages : RelationshipTo<br ALIGN="LEFT"/>supporting_notes : RelationshipTo<br ALIGN="LEFT"/>supporting_websites : RelationshipTo<br ALIGN="LEFT"/>title : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
