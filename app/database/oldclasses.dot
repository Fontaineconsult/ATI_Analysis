    "Law" -> "Webpage" [label="is_documented_by"];
    "Law" -> "Note" [label="is_documented_by"];
    "Law" -> "Message" [label="is_documented_by"];
    "Guideline" -> "Goal" [label="informs"];
    "Guideline" -> "Document" [label="is_documented_by"];
    "Guideline" -> "Webpage" [label="is_documented_by"];
    "Guideline" -> "Note" [label="is_documented_by"];
    "Guideline" -> "Message" [label="is_documented_by"];
    "Directive" -> "Goal" [label="informs"];
    "Directive" -> "Document" [label="is_documented_by"];
    "Directive" -> "Webpage" [label="is_documented_by"];
    "Directive" -> "Note" [label="is_documented_by"];
    "Directive" -> "Message" [label="is_documented_by"];
    "Case" -> "Goal" [label="informs"];
