    "Directive" [color="black", fontcolor="black", label=<{Directive|description : StringProperty<br ALIGN="LEFT"/>effective_date : DateProperty<br ALIGN="LEFT"/>informed_indicators : RelationshipTo<br ALIGN="LEFT"/>last_updated : DateProperty<br ALIGN="LEFT"/>source_institution : StringProperty<br ALIGN="LEFT"/>supporting_documents : RelationshipTo<br ALIGN="LEFT"/>supporting_messages : RelationshipTo<br ALIGN="LEFT"/>supporting_notes : RelationshipTo<br ALIGN="LEFT"/>supporting_websites : RelationshipTo<br ALIGN="LEFT"/>title : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
