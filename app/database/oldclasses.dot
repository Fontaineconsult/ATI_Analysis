    "Project" [color="black", fontcolor="black", label=<{Project|description : StringProperty<br ALIGN="LEFT"/>evidenced_yses : RelationshipTo<br ALIGN="LEFT"/>supporting_documents : RelationshipTo<br ALIGN="LEFT"/>supporting_messages : RelationshipTo<br ALIGN="LEFT"/>supporting_notes : RelationshipTo<br ALIGN="LEFT"/>supporting_websites : RelationshipTo<br ALIGN="LEFT"/>title : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "Process" [color="black", fontcolor="black", label=<{Process|description : StringProperty<br ALIGN="LEFT"/>evidenced_yses : RelationshipTo<br ALIGN="LEFT"/>supporting_documents : RelationshipTo<br ALIGN="LEFT"/>supporting_messages : RelationshipTo<br ALIGN="LEFT"/>supporting_notes : RelationshipTo<br ALIGN="LEFT"/>supporting_websites : RelationshipTo<br ALIGN="LEFT"/>title : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "Procedure" [color="black", fontcolor="black", label=<{Procedure|description : StringProperty<br ALIGN="LEFT"/>evidenced_yses : RelationshipTo<br ALIGN="LEFT"/>supporting_documents : RelationshipTo<br ALIGN="LEFT"/>supporting_messages : RelationshipTo<br ALIGN="LEFT"/>supporting_notes : RelationshipTo<br ALIGN="LEFT"/>supporting_websites : RelationshipTo<br ALIGN="LEFT"/>title : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "Plan" [color="black", fontcolor="black", label=<{Plan|description : StringProperty<br ALIGN="LEFT"/>detailed_procedures : RelationshipTo<br ALIGN="LEFT"/>detailed_processes : RelationshipTo<br ALIGN="LEFT"/>detailed_projects : RelationshipTo<br ALIGN="LEFT"/>detailed_services : RelationshipTo<br ALIGN="LEFT"/>supporting_documents : RelationshipTo<br ALIGN="LEFT"/>supporting_messages : RelationshipTo<br ALIGN="LEFT"/>supporting_notes : RelationshipTo<br ALIGN="LEFT"/>supporting_websites : RelationshipTo<br ALIGN="LEFT"/>title : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "Service" -> "YearSuccessEvidence" [label="is_evidence_for"];
    "Service" -> "Document" [label="is_documented_by"];
    "Service" -> "Webpage" [label="is_documented_by"];
    "Service" -> "Note" [label="is_documented_by"];
    "Service" -> "Message" [label="is_documented_by"];
    "Project" -> "YearSuccessEvidence" [label="is_evidence_for"];
    "Project" -> "Document" [label="is_documented_by"];
    "Project" -> "Webpage" [label="is_documented_by"];
    "Project" -> "Note" [label="is_documented_by"];
    "Project" -> "Message" [label="is_documented_by"];
    "Process" -> "YearSuccessEvidence" [label="is_evidence_for"];
    "Process" -> "Document" [label="is_documented_by"];
    "Process" -> "Webpage" [label="is_documented_by"];
    "Process" -> "Note" [label="is_documented_by"];
    "Process" -> "Message" [label="is_documented_by"];
    "Procedure" -> "YearSuccessEvidence" [label="is_evidence_for"];
    "Procedure" -> "Document" [label="is_documented_by"];
    "Procedure" -> "Webpage" [label="is_documented_by"];
    "Procedure" -> "Note" [label="is_documented_by"];
    "Procedure" -> "Message" [label="is_documented_by"];
    "Plan" -> "Procedure" [label="details"];
    "Plan" -> "Process" [label="details"];
    "Plan" -> "Project" [label="details"];
    "Plan" -> "Service" [label="details"];
