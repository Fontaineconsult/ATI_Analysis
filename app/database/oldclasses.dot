    "Plan" -> "Note" [label="is_documented_by"];
    "Plan" -> "Message" [label="is_documented_by"];
    }




    // Evidence subgraph
    subgraph cluster_Evidence {
    label = "Evidence";
    style = filled;
    color = pink;
    "YearSuccessEvidence" [color="black", fontcolor="black", label=<{YearSuccessEvidence|academic_year : RelationshipTo<br ALIGN="LEFT"/>documentation_status : StringProperty<br ALIGN="LEFT"/>implementation_plan_status : StringProperty<br ALIGN="LEFT"/>notes : RelationshipTo<br ALIGN="LEFT"/>related_success_indicator : RelationshipTo<br ALIGN="LEFT"/>resources_status : StringProperty<br ALIGN="LEFT"/>status_level : RelationshipTo<br ALIGN="LEFT"/>year_identifier : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "StatusLevel" [color="black", fontcolor="black", label=<{StatusLevel|ati_report_evidence_column : StringProperty<br ALIGN="LEFT"/>description_of_documentation : StringProperty<br ALIGN="LEFT"/>description_of_documentation_evidence : StringProperty<br ALIGN="LEFT"/>description_of_procedures : StringProperty<br ALIGN="LEFT"/>description_of_resources : StringProperty<br ALIGN="LEFT"/>notes : RelationshipTo<br ALIGN="LEFT"/>status_level : StringProperty<br ALIGN="LEFT"/>status_value : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "AcademicYear" [color="black", fontcolor="black", label=<{AcademicYear|end_date : DateProperty<br ALIGN="LEFT"/>name : StringProperty<br ALIGN="LEFT"/>start_date : DateProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "YearSuccessEvidence" -> "AcademicYear" [label="evidence_in_year"];
    "YearSuccessEvidence" -> "StatusLevel" [label="status_is"];
    "YearSuccessEvidence" -> "SuccessIndicator" [label="success_indicator_is"];
    "YearSuccessEvidence" -> "Note" [label="has_note"];
    "StatusLevel" -> "Note" [label="has_note"];
    }


    // Committees subgraph
    subgraph cluster_Committees {
    label = "Committees";
    style = filled;
    color = green;
    "ATIWorkingGroup" [color="black", fontcolor="black", label=<{ATIWorkingGroup|description : StringProperty<br ALIGN="LEFT"/>implements_procedure : RelationshipTo<br ALIGN="LEFT"/>implements_process : RelationshipTo<br ALIGN="LEFT"/>implements_project : RelationshipTo<br ALIGN="LEFT"/>implements_service : RelationshipTo<br ALIGN="LEFT"/>name : StringProperty<br ALIGN="LEFT"/>responsible_for : RelationshipTo<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "ATIWorkingGroup" -> "Goal" [label="responsible_for"];
    "ATIWorkingGroup" -> "Procedure" [label="implements"];
    "ATIWorkingGroup" -> "Process" [label="implements"];
    "ATIWorkingGroup" -> "Project" [label="implements"];
    "ATIWorkingGroup" -> "Service" [label="implements"];
    }

    // Individuals subgraph
    subgraph cluster_Individuals {
    label = "Individuals";
    style = filled;
    color = orange;

    "Person" [color="black", fontcolor="black", label=<{Person|email : StringProperty<br ALIGN="LEFT"/>employee_id : StringProperty<br ALIGN="LEFT"/>implements_procedure : RelationshipTo<br ALIGN="LEFT"/>implements_process : RelationshipTo<br ALIGN="LEFT"/>implements_project : RelationshipTo<br ALIGN="LEFT"/>implements_service : RelationshipTo<br ALIGN="LEFT"/>in_ati_working_group : RelationshipTo<br ALIGN="LEFT"/>name : StringProperty<br ALIGN="LEFT"/>title : StringProperty<br ALIGN="LEFT"/>|}>, shape="record", style="solid"];
    "Person" -> "ATIWorkingGroup" [label="participates_in"];
    "Person" -> "Process" [label="implements"];
    "Person" -> "Project" [label="implements"];
    "Person" -> "Procedure" [label="implements"];
    "Person" -> "Service" [label="implements"];
