<configuration>
  <system.webServer>
    <handlers>
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="FastCgiModule"
           scriptProcessor="C:\www\ati\venv\Scripts\python.exe|C:\www\ati\venv\Lib\site-packages\wfastcgi.py"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>
  </system.webServer>
  <appSettings>
    <!-- Set the Python path to include your application's root directory -->
    <add key="PYTHONPATH" value="C:\www\ati\app;C:\www\ati\venv\Lib\site-packages" />
    <!-- Specify the WSGI handler for your Flask app -->
    <add key="WSGI_HANDLER" value="wsgi.app" />
    <!-- Log errors to a file for debugging -->
    <add key="WSGI_LOG" value="C:\www\ati\wfastcgi.log" />
  </appSettings>
</configuration>
