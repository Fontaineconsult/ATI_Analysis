<configuration>
  <system.webServer>
    <handlers>
      <add name="AtiHandler"
           path="*"
           verb="*"
           modules="FastCgiModule"
           scriptProcessor="C:\Program Files\Python311\python.exe|C:\Program Files\Python311\Lib\site-packages\wfastcgi.py"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>
  </system.webServer>
  <appSettings>
  <add key="PYTHONPATH" value="C:\www\ati;C:\www\ati\app;C:\Program Files\Python311\Lib\site-packages" />
  <add key="WSGI_HANDLER" value="wsgi.application" />
    <add key="WSGI_LOG" value="C:\www\ati\app\wfastcgi.log" />
    <add key="WSGI_DEBUG" value="1" />
  </appSettings>
</configuration>
