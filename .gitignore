/classes.dot
/app/.env.development
/.idea/
/app/.env.production
/app/.env.remote
ATI_Analysis.iml

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Neo4j database dumps (real institutional data / PII — never publish)
*.dump

# Local secrets & machine-specific config
.claude/settings.local.json
**/.claude/settings.local.json

# Local auth user store (SQLite sidecar — credentials, never commit)
app/auth_users.sqlite3
app/auth_users.sqlite3-wal
app/auth_users.sqlite3-shm

# Jupyter scratch notebooks (contain connection strings and query output data)
app/database/jupyter/
.ipynb_checkpoints/

# Graphify knowledge-graph output
graphify-out/

# Application logs — the rotating per-process files (app/logging_config.py) and the
# wfastcgi stdout capture. Runtime artifacts, never commit.
app.log
app-*.log
app-*.log.*
wfastcgi.log

# Windows reserved-name artifacts: stray `nul` files left by `>nul` / `2>nul` redirects
# run under cmd/PowerShell. `nul` is a reserved device name, so a real file by that name
# should never exist — ignore it at any depth (currently /nul, /app/database/nul,
# /app/database/tools/report_export/nul).
nul
